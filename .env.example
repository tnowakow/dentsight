# Dentsight Environment Variables - DO NOT COMMIT ACTUAL SECRETS TO GIT

# Database Configuration (Provided by Railway)
DATABASE_URL=postgresql://user:password@host:5432/dentsight

# Authentication
JWT_SECRET=your-super-secret-random-string-here
JWT_EXPIRY=24h

# Edge Connector API Keys (Per-practice keys managed in DB)
EDGE_CONNECTOR_API_KEY=your-edge-connector-key-here

# Alerting & Notifications (Phase 2)
TWILIO_ACCOUNT_SID=your-twilio-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
SENDGRID_API_KEY=your-sendgrid-key
FROM_EMAIL=noreply@dentsight.ai

# Application Configuration
NODE_ENV=production
PORT=3000
CORS_ORIGIN=https://dentsight.ai
