generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Practice {
  id               String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name             String    @db.VarChar(255)
  practiceHash     String    @unique @map("practice_hash") @db.VarChar(64)
  ownerName        String?   @map("owner_name") @db.VarChar(255)
  locationCity     String?   @map("location_city") @db.VarChar(100)
  locationState    String?   @map("location_state") @db.VarChar(50)
  subscriptionTier String?   @map("subscription_tier") @default("founding") @db.VarChar(50)
  createdAt        DateTime  @default(now()) @map("created_at") @db.Timestamptz 
  updatedAt        DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  patients     Patient[]
  appointments Appointment[]
  procedures   Procedure[]
  metrics      Metric[]
  alerts       Alert[]
  expenses     Expense[]

  @@map("practices")
}

model Patient {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId   String   @map("practice_id") @db.Uuid
  patientHash  String   @map("patient_hash") @db.VarChar(64)
  ageBucket    String?  @map("age_bucket") @db.VarChar(20)
  gender       String?  @db.VarChar(10)
  insuranceType String? @map("insurance_type") @db.VarChar(100)
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  practice      Practice @relation(fields: [practiceId], references: [id])
  appointments Appointment[]
  procedures   Procedure[]

  @@unique([practiceId, patientHash])
  @@map("patients")
}

model Appointment {
  time            DateTime @map("time") @db.Timestamptz
  practiceId      String   @map("practice_id") @db.Uuid
  patientHash     String   @map("patient_hash") @db.VarChar(64)
  appointmentType String?  @map("appointment_type") @db.VarChar(50)
  providerId      String?  @map("provider_id") @db.VarChar(100)
  status          String?  @db.VarChar(50)
  productionValue Decimal? @map("production_value") @db.Decimal(12, 2)
  procedureCodes  String[] @map("procedure_codes")

  practice      Practice @relation(fields: [practiceId], references: [id])
  patient       Patient  @relation(fields: [patientHash], references: [patientHash])

  @@id([time, practiceId, patientHash])
  @@map("appointments")
}

model Procedure {
  time            DateTime @map("time") @db.Timestamptz
  practiceId      String   @map("practice_id") @db.Uuid
  patientHash     String   @map("patient_hash") @db.VarChar(64)
  procedureCode   String   @map("procedure_code") @db.VarChar(20)
  procedureName   String?  @map("procedure_name") @db.VarChar(255)
  productionValue Decimal  @map("production_value") @db.Decimal(12, 2)
  renderedBy      String?  @map("rendered_by") @db.VarChar(100)
  status          String?  @db.VarChar(50)

  practice      Practice @relation(fields: [practiceId], references: [id])
  patient       Patient  @relation(fields: [patientHash], references: [patientHash])

  @@id([time, practiceId, patientHash, procedureCode])
  @@map("procedures")
}

model Metric {
  id               String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId       String   @map("practice_id") @db.Uuid
  metricDate       DateTime @map("metric_date") @db.Date
  metricName       String   @map("metric_name") @db.VarChar(100)
  metricValue      Decimal  @map("metric_value") @db.Decimal(12, 4)
  targetValue      Decimal? @map("target_value") @db.Decimal(12, 4)
  industryBenchmark Decimal? @map("industry_benchmark") @db.Decimal(12, 4)
  unit             String?  @db.VarChar(50)

  practice          Practice @relation(fields: [practiceId], references: [id])

  @@unique([practiceId, metricDate, metricName])
  @@map("metrics")
}

model Alert {
  id          String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId  String   @map("practice_id") @db.Uuid
  metricName  String   @map("metric_name") @db.VarChar(100)
  alertType   String   @map("alert_type") @db.VarChar(50)
  message     String   @db.Text
  severity    Int      @default(2)
  isResolved  Boolean  @default(false) @map("is_resolved")
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz
  resolvedAt  DateTime? @map("resolved_at") @db.Timestamptz

  practice      Practice @relation(fields: [practiceId], references: [id])

  @@map("alerts")
}

model Expense {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  practiceId    String   @map("practice_id") @db.Uuid
  expenseDate   DateTime @map("expense_date") @db.Date
  category      String?  @db.VarChar(100)
  subcategory   String?  @db.VarChar(100)
  amount        Decimal  @db.Decimal(12, 2)
  isAddback     Boolean  @default(false) @map("is_addback")
  addbackReason String?  @map("addback_reason") @db.VarChar(255)

  practice      Practice @relation(fields: [practiceId], references: [id])

  @@map("expenses")
}
